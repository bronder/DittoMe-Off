<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme (Default) -->
    <ResourceDictionary x:Key="Light">
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#DDDDDD"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#E8F4FC"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#D4E9F7"/>
    </ResourceDictionary>

    <!-- Dark Theme -->
    <ResourceDictionary x:Key="Dark">
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#252525"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3E3E3E"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#404040"/>
    </ResourceDictionary>

    <!-- Blue Theme -->
    <ResourceDictionary x:Key="Blue">
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#D6E4F0"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#B8D4E8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0066CC"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A365D"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4A6FA5"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#8AB4D9"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#C4DCF0"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#A8CCE8"/>
    </ResourceDictionary>

    <!-- Green Theme -->
    <ResourceDictionary x:Key="Green">
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F0F8F0"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#D6F0D6"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#B8E8B8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2E8B57"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A3D1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#4A7A4A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#8AD98A"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#C4F0C4"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#A8E8A8"/>
    </ResourceDictionary>

    <!-- Purple Theme -->
    <ResourceDictionary x:Key="Purple">
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F8F4FC"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#E8D6F0"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#D4B8E8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7B4FBF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#2D1A3D"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6A4A8A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#B894D4"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#DCC4F0"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#CCA8E8"/>
    </ResourceDictionary>

    <!-- Orange Theme -->
    <ResourceDictionary x:Key="Orange">
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF8F0"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F0E0C8"/>
        <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#E8D0A0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D35400"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#3D2A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8A6A4A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D4B87A"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#F0E0C4"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#E8D4A8"/>
    </ResourceDictionary>

</ResourceDictionary>
