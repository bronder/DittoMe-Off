<Window x:Class="DittoMeOff.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DittoMeOff.ViewModels"
        xmlns:converters="clr-namespace:DittoMeOff.Converters"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="DittoMeOff"
        Width="480" 
        Height="650"
        MinWidth="400" 
        MinHeight="500"
        WindowStartupLocation="Manual"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI Variable"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        SizeChanged="Window_SizeChanged"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        Focusable="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter"/>
        <converters:SyntaxHighlightingConverter x:Key="SyntaxHighlightingConverter"/>
        <converters:ContentFormatToVisibilityConverter x:Key="ContentFormatToVisConverter"/>
        <converters:ImagePreviewVisibilityConverter x:Key="ImagePreviewVisConverter"/>
        <converters:TextPreviewVisibilityConverter x:Key="TextPreviewVisConverter"/>
        <converters:PreviewBadgeConverter x:Key="PreviewBadgeConverter"/>
        <converters:SearchHighlightConverter x:Key="SearchHighlightConverter"/>
        
        <!-- Clipboard Item Template - Dense power user layout with 3-line preview -->
        <DataTemplate x:Key="ClipboardItemTemplate">
            <Border x:Name="ItemBorder"
                    Margin="2,1"
                    Padding="4,4"
                    CornerRadius="4"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    MouseLeftButtonDown="ClipboardItem_MouseLeftButtonDown"
                    Tag="{Binding}"
                    ToolTip="{Binding Content}">
                <Border.ContextMenu>
                    <ContextMenu Style="{DynamicResource DarkContextMenuStyle}">
                        <MenuItem Header="Copy" Click="ContextMenuCopy_Click" Style="{DynamicResource DarkMenuItemStyle}"/>
                        <MenuItem Header="Pin/Unpin" Click="ContextMenuPin_Click" Style="{DynamicResource DarkMenuItemStyle}"/>
                        <Separator/>
                        <MenuItem Header="Delete" Click="ContextMenuDelete_Click" Style="{DynamicResource DarkMenuItemStyle}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3"/>  <!-- Selection accent bar -->
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Selection accent bar (left border) -->
                    <Border x:Name="SelectionBar"
                            Grid.Column="0"
                            Width="3"
                            CornerRadius="2"
                            Background="Transparent"
                            Margin="0,2"/>
                    
                    <!-- Type Icon -->
                    <Border Grid.Column="1"
                            Width="18" Height="18"
                            CornerRadius="3"
                            Background="{DynamicResource CardBrush}"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding ContentTypeIcon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="9"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    
                    <!-- Content - 3-line preview + badge, timestamp right -->
                    <Grid Grid.Column="2"
                          Margin="6,0,8,0"
                          VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 3-line preview text with search highlighting -->
                        <ContentControl Grid.Row="0">
                            <ContentControl.Content>
                                <MultiBinding Converter="{StaticResource SearchHighlightConverter}">
                                    <Binding Path="PreviewText"/>
                                    <Binding Path="DataContext.SearchText" RelativeSource="{RelativeSource AncestorType=ListView}"/>
                                </MultiBinding>
                            </ContentControl.Content>
                        </ContentControl>
                        
                        <!-- Format badge row -->
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="0,4,0,0">
                            <!-- Format Badge pill -->
                            <Border x:Name="FormatBadge"
                                    Padding="5,2"
                                    CornerRadius="4"
                                    Background="{DynamicResource AccentBrush}"
                                    Visibility="{Binding HasFormatBadge, Converter={StaticResource BoolToVisConverter}}"
                                    Cursor="Hand">
                                <TextBlock Text="{Binding FormatBadgeText}"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Right side: timestamp + pin -->
                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0">
                        <TextBlock Text="{Binding TimestampDisplay}"
                                   FontSize="10"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource AccentBrush}"
                                CornerRadius="3"
                                Padding="4,1"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisConverter}}"
                                ToolTip="Pinned">
                            <TextBlock Text="📌"
                                       FontSize="11"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                    <Setter TargetName="SelectionBar" Property="Background" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
                <Trigger SourceName="ItemBorder" Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        
        <!-- Theme-aware Close Button Style -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        
        <!-- Filter Pill Style for quick filters -->
        <Style x:Key="FilterPillStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="PillBorder"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="PillBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="8">
        <DockPanel>
            <!-- Menu Bar at Top -->
            <Menu DockPanel.Dock="Top" 
                  Background="Transparent" 
                  Foreground="{DynamicResource TextBrush}" 
                  Padding="12,8"
                  BorderThickness="0">
                <MenuItem Header="File">
                    <MenuItem Header="Settings..."
                              Command="{Binding OpenSettingsCommand}"
                              InputGestureText="Ctrl+,"/>
                    <Separator/>
                    <MenuItem Header="Exit"
                              Click="Exit_Click"
                              InputGestureText="Alt+F4"/>
                </MenuItem>
            </Menu>

            <!-- Main Content Grid - 2-column layout: list | preview -->
            <Grid x:Name="MainContent" Margin="4,4,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                    <RowDefinition Height="*"/>     <!-- Main content -->
                    <RowDefinition Height="Auto"/>  <!-- Status bar -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ListColumn" Width="280" MinWidth="200" MaxWidth="350"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition x:Name="PreviewColumn" Width="*" MinWidth="300"/>
                </Grid.ColumnDefinitions>
                
                <!-- System Tray Icon -->
                <tb:TaskbarIcon x:Name="TrayIcon"
                                ToolTipText="DittoMeOff"
                                DoubleClickCommand="{Binding ToggleWindowCommand}">
                    <tb:TaskbarIcon.ContextMenu>
                        <ContextMenu Style="{DynamicResource DarkContextMenuStyle}">
                            <MenuItem Header="Show Window" Click="ShowWindow_Click" Style="{DynamicResource DarkMenuItemStyle}"/>
                            <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}" Style="{DynamicResource DarkMenuItemStyle}"/>
                            <Separator/>
                            <MenuItem Header="Exit" Click="Exit_Click" Style="{DynamicResource DarkMenuItemStyle}"/>
                        </ContextMenu>
                    </tb:TaskbarIcon.ContextMenu>
                </tb:TaskbarIcon>

                <!-- Top Toolbar -->
                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                        Margin="4,4,4,4"
                        Padding="8,6"
                        CornerRadius="6"
                        Background="{DynamicResource CardBrush}">
                    <DockPanel>
                        <!-- Center: App title -->
                        <TextBlock Text="📋 Search"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        
                        <!-- Right: Search + Filter + Settings -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <!-- Search box with icon -->
                            <Grid Margin="16,0,0,0" Width="180">
                                <TextBox x:Name="SearchBox"
                                         Width="180"
                                         Padding="8,4,28,4"
                                         FontSize="10"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource BackgroundBrush}"
                                         BorderThickness="1"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="🔍"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,8,0"
                                           IsHitTestVisible="False"
                                           Opacity="0.5"/>
                            </Grid>
                            
                            <!-- Modern Filter Dropdown -->
                            <ComboBox x:Name="FilterCombo"
                                      Width="115"
                                      Margin="8,0,0,0"
                                      Padding="8,6"
                                      FontSize="11"
                                      FontWeight="Medium"
                                      SelectedIndex="0"
                                      SelectionChanged="FilterCombo_SelectionChanged">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Padding" Value="8,6"/>
                                        <Setter Property="FontSize" Value="11"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBoxItem Content="All" Tag=""/>
                                <ComboBoxItem Content="CSS" Tag="Css"/>
                                <ComboBoxItem Content="C#" Tag="CSharp"/>
                                <ComboBoxItem Content="HTML" Tag="Html"/>
                                <ComboBoxItem Content="Image" Tag="Image"/>
                                <ComboBoxItem Content="JS" Tag="JavaScript"/>
                                <ComboBoxItem Content="JSON" Tag="Json"/>
                                <ComboBoxItem Content="Markdown" Tag="Markdown"/>
                                <ComboBoxItem Content="Python" Tag="Python"/>
                                <ComboBoxItem Content="Shell" Tag="Shell"/>
                                <ComboBoxItem Content="SQL" Tag="Sql"/>
                                <ComboBoxItem Content="Text" Tag="Text"/>
                                <ComboBoxItem Content="XML" Tag="Xml"/>
                                <ComboBoxItem Content="YAML" Tag="Yaml"/>
                            </ComboBox>
                            
                            <!-- Settings Button - matches settings page style -->
                            <Button Command="{Binding OpenSettingsCommand}"
                                    Content="⚙ Settings"
                                    Margin="8,0,0,0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="14,8"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border"
                                                            Background="{TemplateBinding Background}"
                                                            CornerRadius="6"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
                
                <!-- Clipboard List Card - compact -->
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Margin="4,0,2,4"
                        CornerRadius="6"
                        Background="{DynamicResource CardBrush}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="Black" Direction="270"/>
                    </Border.Effect>

                    <ListView x:Name="ClipboardListView"
                              ItemsSource="{Binding ClipboardItems}"
                              SelectedItem="{Binding SelectedItem}"
                              ItemTemplate="{StaticResource ClipboardItemTemplate}"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              KeyDown="ClipboardListView_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4,3"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="36"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>
                
                <!-- Splitter between list and preview -->
                <GridSplitter x:Name="MainSplitter"
                              Grid.Row="1"
                              Grid.Column="1"
                              Width="4"
                              Margin="0,0,0,4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              ShowsPreview="True"
                              DragCompleted="MainSplitter_DragCompleted"/>                 
                <!-- Preview Panel - content with header info -->
                <Border Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,4,4"
                        CornerRadius="6"
                        Background="{DynamicResource PreviewBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Visibility="{Binding SelectedItem, Converter={StaticResource ContentFormatToVisConverter}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black" Direction="270"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header info bar with type, size, date/time, app -->
                        <Border Grid.Row="0" 
                                Padding="10,6" 
                                Background="{DynamicResource CardBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <!-- Type Badge -->
                                <Border Padding="6,2" 
                                        CornerRadius="3"
                                        Background="{DynamicResource AccentBrush}"
                                        Margin="0,0,12,0"
                                        Visibility="{Binding SelectedItem.HasFormatBadge, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="{Binding SelectedItem.FormatBadgeIcon}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>
                                </Border>
                                
                                <!-- Size -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="📦" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedItem.SizeDisplay}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- Date/Time -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="🕐" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedItem.DateTimeDisplay}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- App Source -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="💻" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedItem.AppSourceDisplay}"
                                               FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding SelectedItem.AppSource}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Preview Content (image or text - fully scrollable) -->
                        <Grid Grid.Row="1">
                            <!-- Image Preview -->
                            <Border Visibility="{Binding SelectedItem, Converter={StaticResource ImagePreviewVisConverter}}"
                                Background="{DynamicResource PreviewBackgroundBrush}"
                                Padding="8">
                            <Viewbox Stretch="Uniform">
                                <Image Source="{Binding SelectedItem.ImageSource}"
                                       Stretch="Uniform"/>
                            </Viewbox>
                        </Border>
                        
                        <!-- Text Content - full scrollable with syntax highlighting -->
                        <FlowDocumentScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  IsToolBarVisible="False"
                                                  Zoom="100"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="12,8"
                                                  Visibility="{Binding SelectedItem, Converter={StaticResource TextPreviewVisConverter}}">
                            <FlowDocumentScrollViewer.Document>
                                <MultiBinding Converter="{StaticResource SyntaxHighlightingConverter}">
                                    <Binding Path="SelectedItem"/>
                                    <Binding Path="DataContext.SearchText" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </FlowDocumentScrollViewer.Document>
                        </FlowDocumentScrollViewer>
                        </Grid>
                    </Grid>
                </Border>
                
                <!-- Status Bar - slim with keyboard hints -->
                <Border Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Padding="12,6"
                        Background="{DynamicResource HeaderBrush}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="10"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                            <Run Text=" items"/>
                        </TextBlock>
                        <TextBlock DockPanel.Dock="Right"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right">
                            <Run Text="↑↓ arrows • Enter select • Ctrl+F search • Esc clear"/>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <!-- Settings Panel (Overlay) with Fluent styling -->
                <Border x:Name="SettingsPanel"
                        Grid.Row="0" Grid.RowSpan="2"
                        Background="{DynamicResource BackgroundBrush}"
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisConverter}}">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="8" Opacity="0.25" Color="Black" Direction="270"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header with rounded top corners -->
                        <Border Grid.Row="0" 
                                Padding="20,16" 
                                Background="{DynamicResource HeaderBrush}"
                                CornerRadius="6,6,0,0">
                            <Grid>
                                <TextBlock Text="Settings" 
                                           FontSize="22" 
                                           FontWeight="Bold" 
                                           Foreground="{DynamicResource TextBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Content="✕"
                                        HorizontalAlignment="Right"
                                        Command="{Binding CloseSettingsCommand}"
                                        Style="{StaticResource CloseButton}"/>
                            </Grid>
                        </Border>
                        
                        <!-- Settings Content - Tabbed Layout -->
                        <TabControl Grid.Row="1" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    Padding="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border x:Name="TabBorder"
                                                        Padding="14,8"
                                                        Cursor="Hand">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               FontSize="12"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>
                            <!-- General Tab -->
                            <TabItem Header="General">
                                <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- History Count Section -->
                                        <StackPanel Margin="0,0,0,24">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="📋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Maximum History Count" 
                                                           Foreground="{DynamicResource TextBrush}" 
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Slider with labels -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="1" 
                                                           Foreground="{DynamicResource SecondaryTextBrush}" 
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                                <Slider Grid.Column="1"
                                                        Value="{Binding MaxHistoryCount}"
                                                        Minimum="1"
                                                        Maximum="10000"
                                                        Margin="12,0"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" 
                                                           Text="10000" 
                                                           Foreground="{DynamicResource SecondaryTextBrush}" 
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                                
                                                <!-- Real-time value badge - aligned with slider -->
                                                <Border Grid.Column="3"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="16"
                                                        Padding="12,6"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="12">
                                                        <Run Text="{Binding MaxHistoryCount, Mode=OneWay}"/>
                                                        <Run Text=" items"/>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <!-- Divider -->
                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,24" Opacity="0.5"/>
                                        
                                        <!-- Start with Windows Section -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🚀" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Start with Windows" 
                                                               Foreground="{DynamicResource TextBrush}" 
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="Launch DittoMeOff when Windows starts"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontSize="12"
                                                           Margin="24,4,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding AutoStart}"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            
                            <!-- Appearance Tab -->
                            <TabItem Header="Appearance">
                                <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="🎨 Choose a theme" 
                                                   Foreground="{DynamicResource TextBrush}" 
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,12"/>
                                        
                                        <!-- Theme buttons in wrap panel with tighter spacing -->
                                        <WrapPanel>
                                            <RadioButton Content="Ayu Light" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=AyuLight}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Catppuccin" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=CatppuccinLatte}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Dark" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Dark}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Daylight" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Daylight}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Dracula" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Dracula}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Everforest" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=EverforestLight}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="GitHub" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=GitHubLight}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Gruvbox" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Gruvbox}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Light" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Light}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Monokai" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Monokai}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Night Owl" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=NightOwl}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Nord" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Nord}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="One Light" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=OneLight}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Solarized" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=SolarizedLight}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Synthwave" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Synthwave}"
                                                         Margin="0,0,6,6"/>
                                            <RadioButton Content="Tokyo Night" 
                                                         Style="{StaticResource ThemeButton}"
                                                         GroupName="Theme"
                                                         IsChecked="{Binding SelectedTheme, Converter={StaticResource EnumBoolConverter}, ConverterParameter=TokyoNight}"
                                                         Margin="0,0,6,6"/>
                                        </WrapPanel>
                                        
                                        <TextBlock Text="Themes define colors for buttons, text, backgrounds, and more. Click Save Settings to apply."
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,12,0,0"
                                                   Opacity="0.8"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                            
                            <!-- Advanced Tab -->
                            <TabItem Header="Advanced">
                                <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- Hotkey Section -->
                                        <StackPanel Margin="0,0,0,24">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="⌨️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Global Hotkey" 
                                                           Foreground="{DynamicResource TextBrush}" 
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBox x:Name="HotkeyTextBox"
                                                     Text="{Binding CurrentHotkey}"
                                                     Width="250"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,0,0,8"
                                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                                     GotFocus="HotkeyTextBox_GotFocus"
                                                     LostFocus="HotkeyTextBox_LostFocus"/>
                                            <TextBlock x:Name="HotkeyHint"
                                                       Text="Click here, then press your hotkey combination..."
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="12"
                                                       Margin="0,0,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- Divider -->
                                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,24" Opacity="0.5"/>
                                        
                                        <!-- Danger Zone -->
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Danger Zone" 
                                                           FontSize="14" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="#DF2020" 
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                            <!-- Clear History Dropdown -->
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Clear History:" 
                                                           Foreground="{DynamicResource TextBrush}" 
                                                           FontWeight="Medium"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,12,0"/>
                                                <ComboBox x:Name="ClearHistoryCombo" 
                                                          Width="200"
                                                          VerticalAlignment="Center"
                                                          SelectionChanged="ClearHistoryCombo_SelectionChanged">
                                                    <ComboBoxItem Content="Choose an option..." 
                                                                  IsSelected="True"
                                                                  IsEnabled="False"/>
                                                    <ComboBoxItem Content="Clear all (keep pinned)" 
                                                                  Tag="all"/>
                                                    <ComboBoxItem Content="Clear older than 1 day" 
                                                                  Tag="day"/>
                                                    <ComboBoxItem Content="Clear older than 1 week" 
                                                                  Tag="week"/>
                                                    <ComboBoxItem Content="Clear older than 1 month" 
                                                                  Tag="month"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                        
                        <!-- Footer with rounded bottom corners -->
                        <Border Grid.Row="2" 
                                Padding="20,16" 
                                Background="{DynamicResource HeaderBrush}"
                                CornerRadius="0,0,6,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Cancel button as text button -->
                                <Button Content="Cancel"
                                        Grid.Column="1"
                                        Command="{Binding CloseSettingsCommand}"
                                        Cursor="Hand"
                                        Margin="0,0,12,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="12,10"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border"
                                                                Background="{TemplateBinding Background}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <!-- Save Settings as primary button -->
                                <Button Content="Save Settings"
                                        Grid.Column="2"
                                        Command="{Binding SaveSettingsCommand}"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="20,10"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="border"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
